{
  "name": "@telepath-computer/stash",
  "version": "0.3.1",
  "description": "Conflict-free synced folders",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "stash": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && tsc && node -e \"require('node:fs').chmodSync('dist/cli.js', 0o755)\"",
    "prepublishOnly": "npm run build",
    "stash": "node ./src/cli.ts",
    "test": "node --test tests/unit/*.test.ts tests/integration/*.test.ts",
    "test:e2e": "node --env-file-if-exists=.env --test tests/e2e/*.test.ts",
    "test:vm": "dotenv -- ./tests/vm/test-linux-vm.sh",
    "test:all": "npm test && npm run test:e2e",
    "lint": "eslint src/ tests/",
    "format": "prettier --write src/ tests/ docs/",
    "format:check": "prettier --check src/ tests/ docs/"
  },
  "keywords": [
    "sync",
    "files",
    "merge",
    "conflict-free"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/telepath-computer/stash.git"
  },
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@parcel/watcher": "^2.5.6",
    "@rupertsworld/daemon": "^0.1.1",
    "@rupertsworld/disposable": "^0.1.0",
    "@rupertsworld/emitter": "^0.1.0",
    "commander": "^14.0.3",
    "diff-match-patch": "^1.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
