{
  "name": "@telepath-computer/stash",
  "version": "0.1.4",
  "description": "Conflict-free synced folders",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "stash": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "stash": "node ./src/cli.ts",
    "test": "node --test tests/unit/*.test.ts tests/integration/*.test.ts",
    "test:e2e": "node --test tests/e2e/*.test.ts",
    "test:all": "npm test && npm run test:e2e"
  },
  "keywords": [
    "sync",
    "files",
    "merge",
    "conflict-free"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/telepath-computer/stash.git",
    "directory": "code"
  },
  "license": "ISC",
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@parcel/watcher": "^2.5.6",
    "@rupertsworld/disposable": "^0.1.0",
    "@rupertsworld/emitter": "^0.1.0",
    "commander": "^14.0.3",
    "diff-match-patch": "^1.0.5"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3"
  }
}
